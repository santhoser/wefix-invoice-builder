# ─── Authentication ──────────────────────────────────────────────────────────
# Hardcoded login credentials (Phase 1 only)
HARDCODED_USERNAME=admin
HARDCODED_PASSWORD=wefix2024

# ─── Session ─────────────────────────────────────────────────────────────────
# Must be at least 32 characters
SESSION_SECRET=change-me-to-a-secure-32-char-secret!!

# ─── Supabase ─────────────────────────────────────────────────────────────────
# New API key format (available on all projects from June 2025+)
# See: https://github.com/orgs/supabase/discussions/29260
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Publishable key (sb_publishable_...) — safe to expose in browser, replaces legacy anon key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# Secret key (sb_secret_...) — server-side only, never expose in browser, replaces legacy service_role key
SUPABASE_SECRET_KEY=sb_secret_...

# ─── Email (Gmail SMTP) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-gmail@gmail.com

